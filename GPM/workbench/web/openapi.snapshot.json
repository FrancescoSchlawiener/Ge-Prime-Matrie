  "components": {
    "schemas": {
      "CipherEncryptRequest": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "key": {
            "type": "string",
            "title": "Key"
          },
          "mode": {
            "type": "string",
            "title": "Mode",
            "default": "word"
          },
          "profile": {
            "type": "string",
            "title": "Profile",
            "default": "og"
          }
        },
        "type": "object",
        "required": [
          "text",
          "key"
        ],
        "title": "CipherEncryptRequest"
      },
      "CipherRequest": {
        "properties": {
          "base64_gpm": {
            "type": "string",
            "title": "Base64 Gpm"
          },
          "key": {
            "type": "string",
            "title": "Key"
          }
        },
        "type": "object",
        "required": [
          "base64_gpm",
          "key"
        ],
        "title": "CipherRequest"
      },
      "CompareDocumentsInlineRequest": {
        "properties": {
          "doc_a": {
            "$ref": "#/components/schemas/DocumentRefPayload"
          },
          "doc_b": {
            "$ref": "#/components/schemas/DocumentRefPayload"
          },
          "tier": {
            "type": "integer",
            "maximum": 4.0,
            "minimum": 0.0,
            "title": "Tier",
            "default": 4
          }
        },
        "type": "object",
        "required": [
          "doc_a",
          "doc_b"
        ],
        "title": "CompareDocumentsInlineRequest"
      },
      "CompareDocumentsRequest": {
        "properties": {
          "doc_a_ref": {
            "type": "string",
            "title": "Doc A Ref"
          },
          "doc_b_ref": {
            "type": "string",
            "title": "Doc B Ref"
          },
          "profile": {
            "type": "string",
            "title": "Profile",
            "default": "og"
          },
          "tier": {
            "type": "integer",
            "maximum": 4.0,
            "minimum": 0.0,
            "title": "Tier",
            "default": 4
          }
        },
        "type": "object",
        "required": [
          "doc_a_ref",
          "doc_b_ref"
        ],
        "title": "CompareDocumentsRequest"
      },
      "CompareWordsRequest": {
        "properties": {
          "a": {
            "type": "string",
            "maxLength": 100,
            "title": "A"
          },
          "b": {
            "type": "string",
            "maxLength": 100,
            "title": "B"
          },
          "profile": {
            "type": "string",
            "title": "Profile",
            "default": "og"
          },
          "include_steps": {
            "type": "boolean",
            "title": "Include Steps",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "a",
          "b"
        ],
